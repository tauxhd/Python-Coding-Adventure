<nav class="navbar">
  <!-- Logo — hidden on mobile -->
  <a href="/profile" class="navbar-brand">
    <img src="/images/logo.png" alt="Python Adventure Quest" style="height:40px;">
  </a>

  <% if (user && !user.is_admin) { %>
    <!-- Left HUD: rank + XP bar + elixir (no bag here) -->
    <div class="hud-stats">
      <div class="rank-hud-section">
        <div class="rank-hud-badge">
          <%
            const rankImg = {'Code Initiate':'codeinitiate','Spellbinder':'spellbinder','Arcane Scholar':'arcanescholar','Grand Archmage':'grandarchmage'}[user.rank_name];
          %>
          <img src="/images/<%= rankImg %>.png" alt="<%= user.rank_name %>" title="<%= user.rank_name %>">
        </div>
        <span class="rank-hud-name"><%= user.rank_name %></span>
      </div>

      <div class="xp-progress-hud">
        <%
          const RANKS = [
            { name: 'Code Initiate',  minXp: 0,   maxXp: 99 },
            { name: 'Spellbinder',    minXp: 100, maxXp: 299 },
            { name: 'Arcane Scholar', minXp: 300, maxXp: 599 },
            { name: 'Grand Archmage', minXp: 600, maxXp: null },
          ];
          const currentRank = RANKS.find(r => r.name === user.rank_name) || RANKS[0];
          const nextRank = RANKS[RANKS.indexOf(currentRank) + 1] || null;
          const xpIntoRank = user.xp - currentRank.minXp;
          const xpNeeded = nextRank ? nextRank.minXp - currentRank.minXp : 100;
          const xpPercent = Math.min((xpIntoRank / xpNeeded) * 100, 100);
        %>
        <div class="xp-bar-small">
          <div class="xp-fill-small" style="width: <%= xpPercent %>%"></div>
        </div>
        <span class="xp-text"><%= user.xp %></span>
      </div>

      <div class="elixir-shop-group">
        <div class="elixir-hud">
          <img src="/images/elixir.png" alt="Elixir" class="elixir-icon">
          <span class="elixir-val" id="navbar-elixir"><%= user.elixir %></span>
        </div>
        <button type="button" class="plus-btn" onclick="openElixirModal()" title="Buy Elixir">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="12" y1="5" x2="12" y2="19"></line>
            <line x1="5" y1="12" x2="19" y2="12"></line>
          </svg>
        </button>
      </div>
    </div>
  <% } %>

  <!-- Right controls: Play + Bag + desktop nav links + hamburger -->
  <div class="nav-right-controls">
    <% if (user && !user.is_admin) { %>
      <!-- Bag — icon only on mobile (text hidden via CSS) -->
      <a href="/bag" class="bag-btn" title="Inventory">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M6 9l.75-3h10.5l.75 3M9 9v-2a2 2 0 012-2h2a2 2 0 012 2v2m-9 0h12a2 2 0 012 2v10a2 2 0 01-2 2H7a2 2 0 01-2-2V11a2 2 0 012-2z"></path>
        </svg>
        <span class="bag-text">Bag</span>
      </a>
    <% } %>

    <!-- Desktop nav links (inline); mobile: dropdown via hamburger -->
    <div class="navbar-links" id="navLinks">
      <% if (user) { %>
        <% if (user.is_admin) { %>
          <a href="/admin/cards" class="nav-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 19.5A2.5 2.5 0 016.5 17H20"></path>
              <path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"></path>
            </svg>
            Cards
          </a>
          <a href="/admin/players" class="nav-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"></path>
              <circle cx="9" cy="7" r="4"></circle>
              <path d="M23 21v-2a4 4 0 00-3-3.87"></path>
              <path d="M16 3.13a4 4 0 010 7.75"></path>
            </svg>
            Players
          </a>
          <a href="/logout" class="nav-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"></path>
              <polyline points="16 17 21 12 16 7"></polyline>
              <line x1="21" y1="12" x2="9" y2="12"></line>
            </svg>
            Logout
          </a>
        <% } else { %>
          <a href="/profile" class="nav-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"></path>
              <circle cx="12" cy="7" r="4"></circle>
            </svg>
            Profile
          </a>
          <a href="/shop" class="nav-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="9" cy="21" r="1"></circle>
              <circle cx="20" cy="21" r="1"></circle>
              <path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"></path>
            </svg>
            Shop
          </a>
          <a href="/leaderboard" class="nav-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="12 3 20 7.5 20 16.5 12 21 4 16.5 4 7.5 12 3"></polyline>
              <line x1="12" y1="12" x2="20" y2="7.5"></line>
              <line x1="12" y1="12" x2="12" y2="21"></line>
              <line x1="12" y1="12" x2="4" y2="7.5"></line>
            </svg>
            Ranks
          </a>
          <a href="/game/lobby" class="nav-link nav-play">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polygon points="5 3 19 12 5 21 5 3"></polygon>
            </svg>
            Play
          </a>
          <a href="/logout" class="nav-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"></path>
              <polyline points="16 17 21 12 16 7"></polyline>
              <line x1="21" y1="12" x2="9" y2="12"></line>
            </svg>
            Logout
          </a>
        <% } %>
      <% } %>
    </div>

    <!-- Hamburger — mobile only -->
    <% if (user) { %>
    <button class="nav-hamburger" id="navHamburger" aria-label="Toggle menu">☰</button>
    <% } %>
  </div>
</nav>

<% if (user && !user.is_admin) { %>
<!-- Mobile Play Bar — shown only on mobile below navbar -->
<div class="mobile-play-bar">
  <a href="/game/lobby" class="mobile-play-btn">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
      <polygon points="5 3 19 12 5 21 5 3"></polygon>
    </svg>
    Play Now
  </a>
</div>
<% } %>

<!-- Elixir Purchase Modal -->
<div id="elixir-modal" class="elixir-modal" style="display:none;">
  <div class="elixir-modal-content">
    <!-- Purchase Options Screen -->
    <div id="purchase-screen" class="modal-screen">
      <h2>Buy Elixir</h2>
      <p>Answer a Python question to earn Elixir</p>
      <div class="purchase-options">
        <button class="purchase-btn" onclick="selectElixirAmount(10)">
          <span class="amount">+10</span>
          <img src="/images/elixir.png" alt="Elixir" style="height:24px;">
        </button>
        <button class="purchase-btn" onclick="selectElixirAmount(50)">
          <span class="amount">+50</span>
          <img src="/images/elixir.png" alt="Elixir" style="height:28px;">
        </button>
        <button class="purchase-btn" onclick="selectElixirAmount(100)">
          <span class="amount">+100</span>
          <img src="/images/elixir.png" alt="Elixir" style="height:32px;">
        </button>
      </div>
      <button class="modal-close-btn" onclick="closeElixirModal()">✕</button>
    </div>

    <!-- Question Screen -->
    <div id="question-screen" class="modal-screen" style="display:none;">
      <div id="question-content"></div>
      <button class="modal-close-btn" onclick="closeElixirModal()">✕</button>
    </div>

    <!-- Result Screen -->
    <div id="result-screen" class="modal-screen" style="display:none;">
      <div id="result-content"></div>
      <button class="result-btn" onclick="backToPurchaseScreen()">Try Another</button>
      <button class="modal-close-btn" onclick="closeElixirModal()">✕</button>
    </div>
  </div>
</div>

<script>
  (function() {
    const hamburger = document.getElementById('navHamburger');
    const navLinks  = document.getElementById('navLinks');
    if (!hamburger || !navLinks) return;
    hamburger.addEventListener('click', function(e) {
      e.stopPropagation();
      navLinks.classList.toggle('open');
    });
    document.addEventListener('click', function(e) {
      if (!navLinks.contains(e.target) && e.target !== hamburger) {
        navLinks.classList.remove('open');
      }
    });
  })();
</script>

<script>
  let currentElixirAmount = 0;
  let currentQuestion = null;

  function openElixirModal() {
    document.getElementById('elixir-modal').style.display = 'flex';
    showPurchaseScreen();
  }

  function closeElixirModal() {
    document.getElementById('elixir-modal').style.display = 'none';
  }

  function showPurchaseScreen() {
    document.getElementById('purchase-screen').style.display = 'block';
    document.getElementById('question-screen').style.display = 'none';
    document.getElementById('result-screen').style.display = 'none';
  }

  function backToPurchaseScreen() {
    currentElixirAmount = 0;
    currentQuestion = null;
    showPurchaseScreen();
  }

  async function selectElixirAmount(amount) {
    currentElixirAmount = amount;
    try {
      const response = await fetch(`/shop/buy-elixir/${amount}`);
      const data = await response.json();
      currentQuestion = data.question;
      showQuestionScreen(data.question);
    } catch (err) {
      alert('Failed to load question');
    }
  }

  function showQuestionScreen(question) {
    const html = `
      <div class="question-box">
        <h3>Question</h3>
        <p class="question-text">${question.text}</p>
        <div class="options">
          <button class="option-btn" onclick="submitAnswer('a')">A) ${question.options.a}</button>
          <button class="option-btn" onclick="submitAnswer('b')">B) ${question.options.b}</button>
          <button class="option-btn" onclick="submitAnswer('c')">C) ${question.options.c}</button>
          <button class="option-btn" onclick="submitAnswer('d')">D) ${question.options.d}</button>
        </div>
      </div>
    `;
    document.getElementById('question-content').innerHTML = html;
    document.getElementById('purchase-screen').style.display = 'none';
    document.getElementById('question-screen').style.display = 'block';
    document.getElementById('result-screen').style.display = 'none';
  }

  async function submitAnswer(answer) {
    try {
      const response = await fetch('/shop/buy-elixir', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          amount: currentElixirAmount,
          questionId: currentQuestion.id,
          answer: answer
        })
      });
      const data = await response.json();

      if (data.success) {
        document.getElementById('navbar-elixir').textContent = data.newElixir;
        showResultScreen(true, `Correct! You earned +${currentElixirAmount} Elixir!`);
      } else {
        showResultScreen(false, data.error, data.explanation);
      }
    } catch (err) {
      alert('Failed to process answer');
    }
  }

  function showResultScreen(success, message, explanation = '') {
    let html = `
      <div class="result-box ${success ? 'success' : 'error'}">
        <h3>${success ? '✓ Success!' : '✗ Incorrect'}</h3>
        <p>${message}</p>
    `;
    if (explanation) {
      html += `<p class="explanation"><strong>Explanation:</strong> ${explanation}</p>`;
    }
    html += `</div>`;
    document.getElementById('result-content').innerHTML = html;
    document.getElementById('purchase-screen').style.display = 'none';
    document.getElementById('question-screen').style.display = 'none';
    document.getElementById('result-screen').style.display = 'block';
  }
</script>
