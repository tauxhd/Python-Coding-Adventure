<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%- title %> – Admin</title>
  <link rel="stylesheet" href="/css/globals.css">
  <style>
    body { background: var(--bg-deep); }
    .admin-shell { display: flex; min-height: 100vh; }

    /* Sidebar */
    .admin-sidebar {
      width: 220px;
      background: var(--bg-dark);
      border-right: 1px solid var(--border);
      padding: 1.5rem 0;
      flex-shrink: 0;
      position: sticky;
      top: 0;
      height: 100vh;
      overflow-y: auto;
    }
    .sidebar-logo {
      padding: 0 1.2rem 1.2rem;
      border-bottom: 1px solid var(--border);
      margin-bottom: 1rem;
    }
    .sidebar-logo img { width: 100%; max-width: 160px; }
    .sidebar-label {
      font-family: 'Cinzel', serif;
      font-size: 0.65rem;
      letter-spacing: 0.15em;
      color: var(--text-muted);
      text-transform: uppercase;
      padding: 0 1.2rem;
      margin-bottom: 0.4rem;
    }
    .sidebar-nav { list-style: none; margin-bottom: 1.2rem; }
    .sidebar-nav a {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      padding: 0.6rem 1.2rem;
      font-family: 'Cinzel', serif;
      font-size: 0.82rem;
      color: var(--text-muted);
      transition: background 0.15s, color 0.15s;
    }
    .sidebar-nav a:hover { background: var(--bg-hover); color: var(--text-main); }
    .sidebar-nav a.active { background: rgba(91,63,168,0.2); color: var(--gold); border-left: 3px solid var(--gold); }
    .sidebar-nav .nav-icon { font-size: 1rem; flex-shrink: 0; }

    /* Main content */
    .admin-main { flex: 1; padding: 2rem; overflow-x: hidden; }
    .admin-header { margin-bottom: 2rem; }
    .admin-header h1 { font-size: 1.5rem; color: var(--gold); margin-bottom: 0.2rem; }
    .admin-header p  { color: var(--text-muted); font-size: 0.9rem; }

    /* Cards */
    .a-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 1.4rem;
      margin-bottom: 1.5rem;
    }
    .a-card h2 {
      font-size: 0.8rem;
      color: var(--text-muted);
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-bottom: 1rem;
    }

    /* Stat chips */
    .stat-chips { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 2rem; }
    .stat-chip {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1rem 1.4rem;
      flex: 1;
      min-width: 130px;
      text-align: center;
    }
    .stat-chip .chip-val { font-family: 'Cinzel', serif; font-size: 1.8rem; color: var(--gold); display: block; }
    .stat-chip .chip-lbl { font-size: 0.72rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.08em; }

    /* Tables */
    .a-table-wrap { border-radius: 10px; overflow: hidden; border: 1px solid var(--border); }
    table { width: 100%; border-collapse: collapse; }
    thead tr { background: var(--bg-deep); }
    th { font-family:'Cinzel',serif; font-size:0.7rem; letter-spacing:0.1em; color:var(--text-muted); text-transform:uppercase; padding:0.7rem 0.9rem; text-align:left; }
    td { padding:0.7rem 0.9rem; font-size:0.85rem; border-top: 1px solid rgba(255,255,255,0.04); }
    tbody tr:hover { background: var(--bg-hover); }

    /* Status badges */
    .status { display:inline-block; padding:0.15rem 0.6rem; border-radius:10px; font-size:0.72rem; font-family:'Cinzel',serif; }
    .status-active   { background:rgba(61,220,132,0.15); border:1px solid var(--green); color:var(--green); }
    .status-waiting  { background:rgba(240,192,64,0.12); border:1px solid var(--gold); color:var(--gold); }
    .status-finished { background:rgba(255,255,255,0.05); border:1px solid var(--border); color:var(--text-muted); }

    /* Forms */
    .inline-form { display:flex; gap:0.5rem; align-items:center; flex-wrap:wrap; }
    .a-input {
      background: var(--bg-deep);
      border: 1px solid var(--border);
      border-radius: 8px;
      color: var(--text-main);
      padding: 0.45rem 0.8rem;
      font-family: 'Crimson Text', serif;
      font-size: 0.9rem;
      outline: none;
    }
    .a-input:focus { border-color: var(--border-glow); }
    select.a-input option { background: var(--bg-deep); }

    .btn-sm { padding: 0.35rem 0.8rem; font-size: 0.78rem; }
    .btn-danger-sm { background: rgba(255,77,106,0.2); border: 1px solid var(--red); color: var(--red); border-radius: 6px; cursor: pointer; padding: 0.3rem 0.7rem; font-family:'Cinzel',serif; font-size:0.72rem; transition:background 0.15s; }
    .btn-danger-sm:hover { background: rgba(255,77,106,0.35); }

    /* Modal */
    .modal-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.7); z-index:200; align-items:center; justify-content:center; }
    .modal-overlay.open { display:flex; }
    .modal-box { background:var(--bg-card); border:1px solid var(--border-glow); border-radius:16px; padding:2rem; width:100%; max-width:560px; max-height:90vh; overflow-y:auto; }
    .modal-box h3 { font-size:1rem; margin-bottom:1.2rem; color:var(--gold); }
    .modal-close { float:right; cursor:pointer; color:var(--text-muted); font-size:1.2rem; }

    /* Mobile toggle button */
    .sidebar-toggle {
      display: none;
      position: fixed;
      top: 0.75rem;
      left: 0.75rem;
      z-index: 300;
      background: var(--bg-card);
      border: 1px solid var(--border-glow);
      border-radius: 8px;
      padding: 0.45rem 0.6rem;
      cursor: pointer;
      color: var(--text-main);
      font-size: 1.1rem;
      line-height: 1;
    }
    .sidebar-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.55);
      z-index: 150;
    }
    .sidebar-overlay.open { display: block; }

    @media (max-width: 768px) {
      .sidebar-toggle { display: block; }

      .admin-sidebar {
        position: fixed;
        left: -240px;
        top: 0;
        z-index: 200;
        height: 100vh;
        transition: left 0.25s ease;
        box-shadow: 4px 0 20px rgba(0,0,0,0.5);
      }
      .admin-sidebar.open { left: 0; }

      .admin-main { padding: 1rem 0.75rem; padding-top: 3.5rem; }

      .a-table-wrap { overflow-x: auto; }
      table { min-width: 500px; }

      .stat-chips { gap: 0.5rem; }
      .stat-chip { min-width: 100px; padding: 0.75rem 0.9rem; }
      .stat-chip .chip-val { font-size: 1.4rem; }

      .modal-box { margin: 0.75rem; width: calc(100% - 1.5rem); padding: 1.25rem; }
    }

    @media (max-width: 480px) {
      .admin-main { padding: 0.75rem; padding-top: 3.25rem; }
      .admin-header h1 { font-size: 1.2rem; }
      .a-card { padding: 1rem; }
    }
  </style>
</head>
<body>
<button class="sidebar-toggle" id="sidebarToggle" aria-label="Toggle menu">☰</button>
<div class="sidebar-overlay" id="sidebarOverlay"></div>
<div class="admin-shell">
  <!-- Sidebar -->
  <aside class="admin-sidebar" id="adminSidebar">
    <div class="sidebar-logo">
      <img src="/images/logo.png" alt="PAQ Admin">
    </div>
    <div class="sidebar-label">MC Dashboard</div>
    <ul class="sidebar-nav">
      <li><a href="/admin" class="<%= tab === 'overview' ? 'active' : '' %>"><span class="nav-icon">📊</span> Overview</a></li>
      <li><a href="/admin/questions" class="<%= tab === 'questions' ? 'active' : '' %>"><span class="nav-icon">📜</span> Questions</a></li>
      <li><a href="/admin/players" class="<%= tab === 'players' ? 'active' : '' %>"><span class="nav-icon">👥</span> Players</a></li>
    </ul>
    <div class="sidebar-label">Navigation</div>
    <ul class="sidebar-nav">
      <li><a href="/game/lobby"><span class="nav-icon">⚔️</span> Game Lobby</a></li>
      <li><a href="/leaderboard"><span class="nav-icon">🏆</span> Leaderboard</a></li>
      <li><a href="/logout"><span class="nav-icon">🚪</span> Logout</a></li>
    </ul>
  </aside>

  <!-- Main -->
  <main class="admin-main">
    <%- body %>
  </main>
</div>
<script>
  const sidebarToggle = document.getElementById('sidebarToggle');
  const adminSidebar  = document.getElementById('adminSidebar');
  const sidebarOverlay = document.getElementById('sidebarOverlay');
  function closeSidebar() {
    adminSidebar.classList.remove('open');
    sidebarOverlay.classList.remove('open');
  }
  sidebarToggle.addEventListener('click', () => {
    const isOpen = adminSidebar.classList.toggle('open');
    sidebarOverlay.classList.toggle('open', isOpen);
  });
  sidebarOverlay.addEventListener('click', closeSidebar);
</script>
</body>
</html>
