<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Players – Admin</title>
  <link rel="stylesheet" href="/css/globals.css">
  <style>
    body{background:var(--bg-deep);}
    .admin-shell{display:flex;min-height:100vh;}
    .admin-sidebar{width:210px;background:var(--bg-dark);border-right:1px solid var(--border);padding:1.5rem 0;flex-shrink:0;position:sticky;top:0;height:100vh;}
    .sidebar-logo{padding:0 1rem 1.2rem;border-bottom:1px solid var(--border);margin-bottom:1rem;}
    .sidebar-logo img{width:100%;}
    .sidebar-label{font-family:'Cinzel',serif;font-size:0.62rem;letter-spacing:0.15em;color:var(--text-muted);text-transform:uppercase;padding:0 1rem;margin-bottom:0.3rem;}
    .sidebar-nav{list-style:none;margin-bottom:1.2rem;}
    .sidebar-nav a{display:flex;align-items:center;gap:0.5rem;padding:0.55rem 1rem;font-family:'Cinzel',serif;font-size:0.8rem;color:var(--text-muted);transition:all 0.15s;}
    .sidebar-nav a:hover{background:var(--bg-hover);color:var(--text-main);}
    .sidebar-nav a.active{background:rgba(91,63,168,0.2);color:var(--gold);border-left:3px solid var(--gold);}
    .admin-main{flex:1;padding:2rem;overflow-x:hidden;}
    .page-header{margin-bottom:1.5rem;}
    .page-header h1{font-size:1.4rem;color:var(--gold);}
    .page-header p{color:var(--text-muted);font-size:0.88rem;}
    .a-card{background:var(--bg-card);border:1px solid var(--border);border-radius:14px;padding:1.4rem;}
    .a-table-wrap{border-radius:10px;overflow:hidden;border:1px solid var(--border);}
    table{width:100%;border-collapse:collapse;}
    thead tr{background:var(--bg-deep);}
    th{font-family:'Cinzel',serif;font-size:0.68rem;letter-spacing:0.1em;color:var(--text-muted);text-transform:uppercase;padding:0.65rem 0.8rem;text-align:left;}
    td{padding:0.65rem 0.8rem;font-size:0.83rem;border-top:1px solid rgba(255,255,255,0.04);vertical-align:middle;}
    tbody tr:hover{background:var(--bg-hover);}
    .a-input{background:var(--bg-deep);border:1px solid var(--border);border-radius:7px;color:var(--text-main);padding:0.38rem 0.6rem;font-family:'Crimson Text',serif;font-size:0.85rem;outline:none;width:72px;}
    .a-input:focus{border-color:var(--border-glow);}
    .inline-form{display:flex;gap:0.4rem;align-items:center;}
    .btn-sm{padding:0.3rem 0.65rem;font-size:0.75rem;}
  </style>
</head>
<body>
<div class="admin-shell">
  <aside class="admin-sidebar">
    <div class="sidebar-logo"><img src="/images/logo.png" alt="Admin"></div>
    <div class="sidebar-label">Admin</div>
    <ul class="sidebar-nav">
      <li><a href="/admin/cards">📜 Cards</a></li>
      <li><a href="/admin/players" class="active">👥 Players</a></li>
    </ul>
    <ul class="sidebar-nav">
      <li><a href="/logout">🚪 Logout</a></li>
    </ul>
  </aside>

  <main class="admin-main">
    <div class="page-header">
      <h1>Player Management</h1>
      <p>Edit XP and Elixir for any player</p>
    </div>

    <% if (success) { %><div class="alert alert-success" style="margin-bottom:1rem;"><%= success %></div><% } %>

    <div class="a-card">
      <div style="margin-bottom:1rem;">
        <input type="text" id="player-search" class="a-input" style="width:100%;max-width:320px;"
               placeholder="Search by username..." oninput="searchPlayers(this.value)">
      </div>
      <div id="no-results" style="display:none;color:var(--text-muted);font-size:0.85rem;padding:0.5rem 0;">No players found.</div>
      <div class="a-table-wrap">
        <table>
          <thead><tr>
            <th>Player</th><th>Rank</th><th>XP</th><th>Elixir</th>
            <th>Add XP</th><th>Set XP</th><th>Add Elixir</th><th>Set Elixir</th>
          </tr></thead>
          <tbody>
            <% players.forEach(p => { %>
            <tr class="player-row" data-username="<%= p.username.toLowerCase() %>">
              <td>
                <div style="display:flex;align-items:center;gap:0.5rem;">
                  <div style="width:26px;height:26px;border-radius:50%;background:linear-gradient(135deg,#4a26a8,#b04dff);display:flex;align-items:center;justify-content:center;font-family:'Cinzel',serif;font-size:0.72rem;color:#fff;flex-shrink:0;">
                    <%= p.username.charAt(0).toUpperCase() %>
                  </div>
                  <span style="font-family:'Cinzel',serif;font-size:0.83rem;"><%= p.username %></span>
                </div>
              </td>
              <td>
                <%
                  const aRImg = {'Code Initiate':'codeinitiate','Spellbinder':'spellbinder','Arcane Scholar':'arcanescholar','Grand Archmage':'grandarchmage'}[p.rank_name];
                  const aRS = {'Code Initiate':{border:'#666',glow:'rgba(180,180,200,0.15)',tc:'#bbb',bg:'linear-gradient(135deg,#2a2a35,#3a3a45)'},'Spellbinder':{border:'#4ab3ff',glow:'rgba(74,179,255,0.2)',tc:'#4ab3ff',bg:'linear-gradient(135deg,#0d2035,#1a3a55)'},'Arcane Scholar':{border:'#b04dff',glow:'rgba(176,77,255,0.25)',tc:'#c87dff',bg:'linear-gradient(135deg,#1a0d35,#2e1555)'},'Grand Archmage':{border:'#f0c040',glow:'rgba(240,192,64,0.3)',tc:'#f0c040',bg:'linear-gradient(135deg,#2a1a00,#4a3000)'}}[p.rank_name];
                %>
                <div style="display:inline-flex;align-items:center;gap:0.4rem;background:<%= aRS.bg %>;border:1px solid <%= aRS.border %>;border-radius:8px;padding:0.25rem 0.6rem 0.25rem 0.3rem;box-shadow:0 0 8px <%= aRS.glow %>;">
                  <img src="/images/<%= aRImg %>.png" style="height:22px;width:22px;object-fit:contain;filter:drop-shadow(0 0 3px <%= aRS.border %>);">
                  <span style="font-family:'Cinzel',serif;font-size:0.68rem;color:<%= aRS.tc %>;white-space:nowrap;"><%= p.rank_name %></span>
                </div>
              </td>
              <td style="color:var(--gold);font-family:'Cinzel',serif;font-size:0.9rem;"><%= p.xp %></td>
              <td style="color:var(--p2-color);font-family:'Cinzel',serif;font-size:0.9rem;"><%= p.elixir %></td>
              <td>
                <form action="/admin/players/give/<%= p.id %>" method="POST" class="inline-form">
                  <input type="hidden" name="type" value="xp">
                  <input type="number" name="amount" class="a-input" value="10" min="0">
                  <button type="submit" class="btn btn-gold btn-sm">+</button>
                </form>
              </td>
              <td>
                <form action="/admin/players/set/<%= p.id %>" method="POST" class="inline-form">
                  <input type="hidden" name="type" value="xp">
                  <input type="number" name="amount" class="a-input" value="<%= p.xp %>" min="0">
                  <button type="submit" class="btn btn-outline btn-sm">Set</button>
                </form>
              </td>
              <td>
                <form action="/admin/players/give/<%= p.id %>" method="POST" class="inline-form">
                  <input type="hidden" name="type" value="elixir">
                  <input type="number" name="amount" class="a-input" value="50" min="0">
                  <button type="submit" class="btn btn-primary btn-sm">+</button>
                </form>
              </td>
              <td>
                <form action="/admin/players/set/<%= p.id %>" method="POST" class="inline-form">
                  <input type="hidden" name="type" value="elixir">
                  <input type="number" name="amount" class="a-input" value="<%= p.elixir %>" min="0">
                  <button type="submit" class="btn btn-outline btn-sm">Set</button>
                </form>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</div>
<script>
  function searchPlayers(query) {
    const q = query.toLowerCase().trim();
    const rows = document.querySelectorAll('.player-row');
    let visible = 0;
    rows.forEach(row => {
      const match = !q || row.dataset.username.includes(q);
      row.style.display = match ? '' : 'none';
      if (match) visible++;
    });
    document.getElementById('no-results').style.display = visible === 0 ? 'block' : 'none';
  }
</script>
</body>
</html>
