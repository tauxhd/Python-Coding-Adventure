<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Room <%= roomCode %> – Python Adventure Quest</title>
  <link rel="stylesheet" href="/css/globals.css">
  <style>
    body {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      background:
        radial-gradient(ellipse at 50% 40%, rgba(74,38,168,0.25) 0%, transparent 60%),
        var(--bg-deep);
      text-align: center;
    }
    .room-card {
      max-width: 480px;
      width: 100%;
      padding: 1rem;
    }
    .room-logo { margin-bottom: 1.5rem; }
    .room-logo img { width: 200px; }

    .room-box {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 2.5rem 2rem;
      box-shadow: 0 0 50px rgba(91,63,168,0.25);
    }
    .room-box h2 { font-size: 1rem; color: var(--text-muted); margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 0.15em; }

    .room-code {
      font-family: 'Cinzel', serif;
      font-size: 2.8rem;
      font-weight: 700;
      letter-spacing: 0.4em;
      color: var(--gold);
      text-shadow: 0 0 20px rgba(240,192,64,0.6);
      margin: 0.5rem 0 1rem;
    }
    .copy-btn {
      font-size: 0.8rem;
      padding: 0.4rem 1.2rem;
      margin-bottom: 1rem;
    }

    .qr-section {
      margin-bottom: 2rem;
      padding-top: 1rem;
      border-top: 1px solid var(--border);
    }
    .qr-section h3 {
      font-size: 0.75rem;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.12em;
      margin-bottom: 0.8rem;
    }
    .qr-container {
      background: linear-gradient(135deg, rgba(91,63,168,0.08), rgba(176,77,255,0.04));
      border: 1px solid rgba(176,77,255,0.2);
      border-radius: 12px;
      padding: 1rem;
      display: flex;
      justify-content: center;
    }
    .qr-container img {
      max-width: 220px;
      height: auto;
      border-radius: 8px;
    }

    .players-row {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1.5rem;
      margin: 1.5rem 0;
    }
    .player-slot {
      flex: 1;
      background: var(--bg-deep);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1rem;
      min-height: 90px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.4rem;
    }
    .player-slot.p1 { border-color: rgba(74,179,255,0.4); }
    .player-slot.p2 { border-color: rgba(176,77,255,0.4); }
    .player-slot .slot-name { font-family: 'Cinzel', serif; font-size: 0.95rem; }
    .player-slot .slot-rank { font-size: 0.75rem; color: var(--text-muted); }
    .vs { font-family: 'Cinzel', serif; font-size: 1.4rem; color: var(--text-muted); flex-shrink: 0; }

    .waiting-anim {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.3rem;
      color: var(--text-muted);
      font-size: 0.9rem;
      margin-bottom: 1.5rem;
    }
    .dot {
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--p2-color);
      animation: pulse 1.4s ease-in-out infinite;
    }
    .dot:nth-child(2) { animation-delay: 0.2s; }
    .dot:nth-child(3) { animation-delay: 0.4s; }
    @keyframes pulse {
      0%, 80%, 100% { transform: scale(0.6); opacity: 0.3; }
      40% { transform: scale(1.2); opacity: 1; }
    }

    #status-msg { color: var(--green); font-family: 'Cinzel', serif; font-size: 0.95rem; min-height: 1.4rem; }

    .battle-btn { display: none; }
  </style>
</head>
<body>
  <div class="room-card">
    <div class="room-logo">
      <img src="/images/logo.png" alt="Python Adventure Quest">
    </div>

    <div class="room-box">
      <h2>Room Code</h2>
      <div class="room-code" id="roomCode"><%= roomCode %></div>
      <button class="btn btn-outline copy-btn" onclick="copyCode()">Copy Code</button>

      <% if (qrCodeUrl) { %>
      <div class="qr-section">
        <h3>📱 Scan to Join</h3>
        <div class="qr-container">
          <img src="<%= qrCodeUrl %>" alt="QR Code to join game">
        </div>
      </div>
      <% } %>

      <div class="players-row">
        <div class="player-slot p1">
          <span class="slot-name glow-blue"><%= game.p1_username %></span>
          <span class="slot-rank"><%= game.p1_rank %></span>
        </div>
        <span class="vs">VS</span>
        <div class="player-slot p2" id="p2-slot">
          <% if (game.p2_username) { %>
            <span class="slot-name glow-purple"><%= game.p2_username %></span>
            <span class="slot-rank"><%= game.p2_rank %></span>
          <% } else { %>
            <span style="color:var(--text-muted);font-size:0.85rem;">Waiting...</span>
          <% } %>
        </div>
      </div>

      <div class="waiting-anim" id="waiting-row">
        <span>Waiting for opponent</span>
        <div class="dot"></div><div class="dot"></div><div class="dot"></div>
      </div>

      <div id="status-msg"></div>

      <a href="/game/play/<%= roomCode %>" class="btn btn-primary btn-full battle-btn" id="battle-btn">
        ⚔ Enter the Arena
      </a>
    </div>
  </div>

  <script src="/socket.io/socket.io.js"></script>
  <script>
    const roomCode = '<%= roomCode %>';
    const currentUser = '<%= user.username %>';
    const gameStatus = '<%= game.status %>';

    const socket = io();
    socket.emit('join-room', { roomCode });

    socket.on('game-ready', ({ p1, p2 }) => {
      document.getElementById('waiting-row').style.display = 'none';
      document.getElementById('status-msg').textContent = `${p1} vs ${p2} — Ready!`;
      document.getElementById('battle-btn').style.display = 'inline-block';

      // Auto-redirect after 2 seconds
      setTimeout(() => {
        window.location.href = `/game/play/${roomCode}`;
      }, 2000);
    });

    socket.on('player-waiting', ({ username }) => {
      document.getElementById('status-msg').textContent = `${username} is in the room`;
    });

    // Player2 loads this page after game is already active — auto-redirect them too
    if (gameStatus === 'active') {
      document.getElementById('waiting-row').style.display = 'none';
      document.getElementById('status-msg').textContent = 'Opponent found! Entering the arena...';
      document.getElementById('battle-btn').style.display = 'inline-block';
      setTimeout(() => {
        window.location.href = `/game/play/${roomCode}`;
      }, 2000);
    }

    function copyCode() {
      navigator.clipboard.writeText(roomCode);
      const btn = document.querySelector('.copy-btn');
      btn.textContent = 'Copied!';
      setTimeout(() => btn.textContent = 'Copy Code', 2000);
    }
  </script>
</body>
</html>
